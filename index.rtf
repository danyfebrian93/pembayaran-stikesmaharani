\
        async function handleUpload(e) \{\
            e.preventDefault();\
            toggleLoader(true);\
            const fileInput = document.getElementById('mhsFile');\
            if (!fileInput.files[0]) \{\
                Swal.fire("Peringatan", "Pilih file bukti pembayaran terlebih dahulu.", "warning");\
                toggleLoader(false);\
                return;\
            \}\
            const file = fileInput.files[0];\
            const reader = new FileReader();\
            reader.onload = async function() \{\
                const base64 = reader.result.split(',')[1];\
                const res = await callGAS("SUBMIT_PAYMENT", \{\
                    username: currentUser.username,\
                    name: currentUser.name,\
                    nominal: parseInt(document.getElementById('mhsNominal').value.replace(/\\./g, '')),\
                    semester: document.getElementById('mhsSemester').value,\
                    jenis: document.getElementById('mhsJenis').value,\
                    fileName: file.name,\
                    mimeType: file.type,\
                    fileBase64: base64\
                \});\
                if (res.success) \{\
                    Swal.fire("Berhasil", "Bukti pembayaran telah terkirim.", "success");\
                    document.getElementById('uploadForm').reset();\
                    document.getElementById('mhsFileName').innerText = "Klik untuk pilih file";\
                    loadMahasiswaData();\
                \} else \{\
                    Swal.fire("Gagal", res.message, "error");\
                \}\
                toggleLoader(false);\
            \};\
            reader.readAsDataURL(file);\
        \}\
\
        async function verifyAction(id, status, reason = "") \{\
            toggleLoader(true);\
            const res = await callGAS("VERIFY_PAYMENT", \{ id, status, reason \});\
            if (res.success) \{\
                Swal.fire("Berhasil", "Data berhasil diperbarui.", "success");\
                loadAdminData();\
            \}\
            toggleLoader(false);\
        \}\
\
        function openModalTolak(id) \{\
            currentVerifyId = id;\
            document.getElementById('modalTolak').classList.remove('hidden');\
        \}\
\
        function closeModalTolak() \{\
            document.getElementById('modalTolak').classList.add('hidden');\
        \}\
\
        function submitTolak() \{\
            const reason = document.getElementById('tolakAlasan').value;\
            if(!reason) return Swal.fire("Peringatan", "Alasan wajib diisi.", "warning");\
            closeModalTolak();\
            verifyAction(currentVerifyId, 'Ditolak', reason);\
        \}\
\
        function toggleLoader(show) \{\
            const l = document.getElementById('loaderGlobal');\
            show ? l.classList.remove('hidden') : l.classList.add('hidden');\
        \}\
\
        function updateFileName(input) \{\
            document.getElementById('mhsFileName').innerText = input.files[0] ? input.files[0].name : "Klik untuk pilih file";\
        \}\
\
        function logout() \{\
            currentUser = null;\
            switchView('view-login');\
        \}\
    </script>\
