    <script>\
        let currentVerifyId = null;\
\
        function formatRp(angka) \{\
            return new Intl.NumberFormat('id-ID', \{ style: 'currency', currency: 'IDR', minimumFractionDigits: 0 \}).format(angka);\
        \}\
\
        function formatCurrencyInput(input) \{\
            let value = input.value.replace(/[^0-9]/g, '');\
            if (value === "") \{ input.value = ""; return; \}\
            input.value = new Intl.NumberFormat('id-ID').format(value);\
        \}\
\
        function switchView(viewId) \{\
            ['view-login', 'view-mahasiswa', 'view-admin'].forEach(id => document.getElementById(id).classList.add('hidden-view'));\
            document.getElementById(viewId).classList.remove('hidden-view');\
        \}\
\
        async function handleLogin(e) \{\
            e.preventDefault();\
            toggleLoader(true);\
            const username = document.getElementById('username').value;\
            const password = document.getElementById('password').value;\
            const res = await callGAS("LOGIN", \{ username, password \});\
\
            if (res.success) \{\
                currentUser = res;\
                if (res.role === "Admin") \{\
                    switchView('view-admin');\
                    loadAdminData();\
                \} else \{\
                    document.getElementById('mhsNameDisplay').innerText = res.name;\
                    switchView('view-mahasiswa');\
                    loadMahasiswaData();\
                \}\
            \} else \{\
                Swal.fire("Gagal", res.message, "error");\
            \}\
            toggleLoader(false);\
        \}\
\
        async function loadMahasiswaData() \{\
            const res = await callGAS("GET_MHS_DATA", \{ username: currentUser.username \});\
            const tbody = document.getElementById('mhsTableBody');\
            tbody.innerHTML = '';\
\
            if (res.success && res.data.length > 0) \{\
                res.data.forEach(item => \{\
                    tbody.innerHTML += `\
                        <tr class="hover:bg-slate-50/50 transition-colors">\
                            <td class="py-5 px-6 text-[10px] text-slate-400 font-bold">$\{item.date\}</td>\
                            <td class="py-5 px-6">\
                                <div class="font-black text-slate-800 text-xs uppercase">$\{item.semester\}</div>\
                                <div class="text-[9px] text-accent font-black uppercase mt-0.5">$\{item.jenis\}</div>\
                            </td>\
                            <td class="py-5 px-6 text-right font-black text-slate-900 text-sm">$\{formatRp(item.nominal)\}</td>\
                            <td class="py-5 px-6 text-center">\
                                <span class="status-badge px-4 py-1.5 rounded-full text-[9px] font-black uppercase\
                                    $\{item.status === 'Diterima' ? 'bg-green-100 text-green-700' : item.status === 'Ditolak' ? 'bg-red-100 text-red-700' : 'bg-amber-100 text-amber-700'\}">\
                                    $\{item.status\}\
                                </span>\
                            </td>\
                        </tr>\
                    `;\
                \});\
            \} else \{\
                tbody.innerHTML = `<tr><td colspan="4" class="py-12 text-center text-slate-300 italic font-bold">Belum ada riwayat pembayaran.</td></tr>`;\
            \}\
        \}\
\
        async function loadAdminData() \{\
            const res = await callGAS("GET_ADMIN_DATA");\
            const tbody = document.getElementById('adminTableBody');\
            tbody.innerHTML = '';\
\
            if (res.success) \{\
                // Update Statistik\
                document.getElementById('statTotal').innerText = res.data.length;\
                document.getElementById('statWait').innerText = res.data.filter(i => i.status === 'Menunggu').length;\
                document.getElementById('statSuccess').innerText = res.data.filter(i => i.status === 'Diterima').length;\
                document.getElementById('statReject').innerText = res.data.filter(i => i.status === 'Ditolak').length;\
\
                res.data.forEach(item => \{\
                    tbody.innerHTML += `\
                        <tr class="hover:bg-slate-50/50 transition-colors">\
                            <td class="py-6 px-10">\
                                <div class="font-black text-slate-800 text-xs uppercase">PAY-$\{item.id.slice(-6).toUpperCase()\}</div>\
                                <div class="text-[9px] text-slate-400 font-bold uppercase">$\{item.date\}</div>\
                            </td>\
                            <td class="py-6 px-10">\
                                <div class="font-black text-slate-700 text-sm uppercase">$\{item.name\}</div>\
                                <div class="text-[10px] text-slate-400 font-bold uppercase">NIM: $\{item.username\}</div>\
                            </td>\
                            <td class="py-6 px-10">\
                                <div class="text-[10px] text-slate-400 font-bold uppercase">$\{item.semester\}</div>\
                                <div class="font-black text-slate-900 text-sm uppercase">$\{formatRp(item.nominal)\}</div>\
                            </td>\
                            <td class="py-6 px-10 text-center">\
                                <span class="status-badge px-5 py-2 rounded-xl text-[10px] font-black uppercase \
                                    $\{item.status === 'Diterima' ? 'bg-green-100 text-green-700' : item.status === 'Ditolak' ? 'bg-red-100 text-red-700' : 'bg-yellow-100 text-yellow-700'\}">\
                                    $\{item.status\}\
