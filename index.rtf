        async function callGAS(action, payload = \{\}) \{\
            // Validasi URL sebelum melakukan fetch\
            if (!GAS_URL || GAS_URL.includes("URL_WEB_APP")) \{\
                Swal.fire("Konfigurasi Salah", "URL Web App belum diatur di dalam kode HTML.", "error");\
                return \{ success: false, message: "URL tidak valid" \};\
            \}\
\
            try \{\
                const response = await fetch(GAS_URL, \{\
                    method: "POST",\
                    body: JSON.stringify(\{ action, payload \})\
                \});\
                return await response.json();\
            \} catch (error) \{\
                console.error("Error GAS:", error);\
                return \{ success: false, message: "Koneksi ke server gagal. Pastikan URL benar dan Apps Script sudah di-deploy sebagai 'Anyone'." \};\
            \}\
        \}\
